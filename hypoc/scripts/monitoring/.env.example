# Docker & System Monitoring Configuration
# Copy this file to .env and customize values

# ============================================================================
# Log Rotation Settings
# ============================================================================

# Maximum log size in MB before rotation (default: 100)
MAX_LOG_SIZE_MB=100

# Number of rotated logs to keep per container (default: 7)
KEEP_ROTATED=7

# Directory where Docker stores container logs
# Default: /var/lib/docker/containers
LOG_DIR=/var/lib/docker/containers

# Directory where rotated logs are backed up
# Default: /var/log/docker-backups
BACKUP_DIR=/var/log/docker-backups

# ============================================================================
# Alert Thresholds
# ============================================================================

# CPU usage alert threshold in percent (0 = disabled)
ALERT_CPU_THRESHOLD=80

# Memory usage alert threshold in percent (0 = disabled)
ALERT_MEM_THRESHOLD=90

# Disk usage alert threshold in percent (0 = disabled)
ALERT_DISK_THRESHOLD=85

# ============================================================================
# Monitoring Settings
# ============================================================================

# Default refresh interval in seconds for watch mode
DEFAULT_WATCH_INTERVAL=5

# Enable/disable colored output (true/false)
ENABLE_COLORS=true

# Log output format (text/json/compact)
LOG_FORMAT=text

# Primary disk mount point to monitor (default: /)
# Set this to your data/app mount point (e.g., /mnt/ssd500, /data, /opt)
MONITOR_DISK_PATH=/

# ============================================================================
# Notification Settings (Optional - for future expansion)
# ============================================================================

# Email for alerts (leave empty to disable)
ALERT_EMAIL=

# Slack webhook URL (leave empty to disable)
SLACK_WEBHOOK_URL=

# PagerDuty integration key (leave empty to disable)
PAGERDUTY_KEY=
