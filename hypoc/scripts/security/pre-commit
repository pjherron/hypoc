#!/bin/bash
# Security Pre-Commit Hook
# Runs before every commit to catch security issues early

set -e

echo "🔒 Running security pre-commit checks..."

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED_FILES" ]; then
  echo "✅ No files to check"
  exit 0
fi

# Check for git-secrets or gitleaks
HAS_SECRET_SCANNER=false
if command -v gitleaks &> /dev/null; then
  SECRET_SCANNER="gitleaks"
  HAS_SECRET_SCANNER=true
elif command -v git-secrets &> /dev/null; then
  SECRET_SCANNER="git-secrets"
  HAS_SECRET_SCANNER=true
fi

# 1. Secret Scanning
echo "🔍 Scanning for secrets..."
if [ "$HAS_SECRET_SCANNER" = true ]; then
  if [ "$SECRET_SCANNER" = "gitleaks" ]; then
    gitleaks protect --staged --verbose || {
      echo "❌ Secret detected! Run 'gitleaks protect --staged' to see details"
      exit 1
    }
  elif [ "$SECRET_SCANNER" = "git-secrets" ]; then
    git secrets --pre_commit_hook -- "$@" || {
      echo "❌ Secret detected!"
      exit 1
    }
  fi
else
  echo "⚠️  No secret scanner installed. Recommend: brew install gitleaks"
  echo "   Continuing without secret scanning..."
fi

# 2. Check for common dangerous patterns
echo "🔍 Checking for dangerous patterns..."
DANGEROUS_PATTERNS=(
  "password.*=.*['\"]"
  "api[_-]?key.*=.*['\"]"
  "secret.*=.*['\"]"
  "token.*=.*['\"]"
  "eval\("
  "dangerouslySetInnerHTML"
)

for PATTERN in "${DANGEROUS_PATTERNS[@]}"; do
  if echo "$STAGED_FILES" | xargs grep -n -E "$PATTERN" 2>/dev/null; then
    echo "⚠️  Potentially dangerous pattern found: $PATTERN"
    echo "   Review before committing. To proceed anyway: git commit --no-verify"
  fi
done

# 3. Dependency Audit (if package-lock.json is staged)
if echo "$STAGED_FILES" | grep -q "package-lock.json"; then
  if [ -f "package-lock.json" ]; then
    echo "📦 Auditing dependencies..."
    npm audit --audit-level=high || {
      echo "⚠️  High/critical vulnerabilities found!"
      echo "   Run 'npm audit fix' to resolve"
      echo "   To commit anyway: git commit --no-verify"
      exit 1
    }
  fi
fi

# 4. Run ESLint on JavaScript/TypeScript files (if available)
JS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|ts|jsx|tsx)$' || true)
if [ -n "$JS_FILES" ] && [ -f ".eslintrc.json" ] || [ -f ".eslintrc.js" ]; then
  echo "🔧 Running ESLint security checks..."
  npx eslint $JS_FILES 2>/dev/null || {
    echo "⚠️  ESLint violations found"
    echo "   Fix issues or commit with --no-verify"
  }
fi

# 5. Check file sizes (prevent accidental large file commits)
echo "📏 Checking file sizes..."
for FILE in $STAGED_FILES; do
  if [ -f "$FILE" ]; then
    SIZE=$(wc -c < "$FILE" | xargs)
    if [ "$SIZE" -gt 1048576 ]; then  # 1MB
      echo "⚠️  Large file detected: $FILE ($(numfmt --to=iec $SIZE))"
      echo "   Consider using Git LFS or excluding from repo"
    fi
  fi
done

# 6. Verify no .env files are staged
if echo "$STAGED_FILES" | grep -E '\.env$|\.env\..*$' | grep -v '\.example$' | grep -v '\.template$'; then
  echo "❌ .env file detected in staged files!"
  echo "   Never commit .env files. Add to .gitignore"
  exit 1
fi

# 7. Claude Flow verification (if available)
if command -v npx &> /dev/null && command -v jq &> /dev/null; then
  echo "📊 Checking code quality..."
  VERIFY_RESULT=$(npx claude-flow@alpha verify check --threshold 0.90 --json 2>/dev/null || echo '{"overallScore":0.90,"passed":true}')
  
  SCORE=$(echo "$VERIFY_RESULT" | jq -r '.overallScore // 0.90' 2>/dev/null || echo "0.90")
  PASSED=$(echo "$VERIFY_RESULT" | jq -r '.passed // true' 2>/dev/null || echo "true")
  
  if [ "$PASSED" = "false" ]; then
    echo "⚠️  Code quality below threshold: $SCORE"
    echo "   Review changes or adjust threshold"
  else
    echo "✅ Code quality check passed: $SCORE"
  fi
fi

echo ""
echo "✅ All pre-commit security checks passed"
echo ""
exit 0
