# OpenCode Web (Browser-Native, No VNC)
FROM ubuntu:22.04

# Avoid prompts from apt
ENV DEBIAN_FRONTEND=noninteractive

# Set locale
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en
ENV LC_ALL=en_US.UTF-8

# Install base dependencies
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    build-essential \
    ca-certificates \
    gnupg \
    lsb-release \
    sudo \
    locales \
    vim \
    nano \
    jq \
    ripgrep \
    fd-find \
    bat \
    && locale-gen en_US.UTF-8 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22 LTS
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Fix npm if needed and upgrade
RUN npm cache clean --force || true \
    && npm install -g npm@latest || (npm install -g npm@10 && npm install -g npm@latest)

# Install Python 3.12
RUN apt-get update && apt-get install -y \
    software-properties-common \
    && add-apt-repository ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y \
    python3.12 \
    python3.12-venv \
    python3.12-dev \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1 \
    && python3.12 -m ensurepip --upgrade \
    && python3 -m pip install --upgrade pip setuptools wheel \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install security tools
RUN ARCH=$(dpkg --print-architecture) && \
    echo "Detected architecture: $ARCH" && \
    if [ "$ARCH" = "arm64" ]; then \
        GITLEAKS_ARCH="arm64"; \
    elif [ "$ARCH" = "amd64" ]; then \
        GITLEAKS_ARCH="x64"; \
    else \
        echo "Unsupported architecture: $ARCH" && exit 1; \
    fi && \
    echo "Downloading gitleaks for: linux_${GITLEAKS_ARCH}" && \
    wget -O /tmp/gitleaks.tar.gz "https://github.com/gitleaks/gitleaks/releases/download/v8.18.1/gitleaks_8.18.1_linux_${GITLEAKS_ARCH}.tar.gz" && \
    tar xzf /tmp/gitleaks.tar.gz -C /usr/local/bin && \
    rm /tmp/gitleaks.tar.gz && \
    chmod +x /usr/local/bin/gitleaks && \
    echo "Installing semgrep via pip" && \
    pip3 install --no-cache-dir semgrep

# Install OpenCode CLI and related tools
RUN npm install -g \
    opencode-ai \
    ecc-universal \
    @claude-flow/cli \
    snyk \
    eslint \
    typescript \
    && npm cache clean --force

# Create non-root user
ARG USERNAME=developer
ARG USER_UID=1000
ARG USER_GID=$USER_UID

RUN groupadd --gid $USER_GID $USERNAME \
    && useradd --uid $USER_UID --gid $USER_GID -m $USERNAME -s /bin/bash \
    && echo "$USERNAME ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME

# Set up workspace
WORKDIR /workspace
RUN chown -R $USERNAME:$USERNAME /workspace

# Copy workspace configuration
COPY --chown=$USERNAME:$USERNAME . /workspace/

# Install Python dependencies if requirements.txt exists
RUN if [ -f requirements.txt ]; then \
    pip3 install --no-cache-dir -r requirements.txt; \
    fi

# Switch to non-root user
USER $USERNAME

# Configure Git
RUN git config --global init.defaultBranch main \
    && git config --global pull.rebase false \
    && git config --global core.editor "vim"

# Set up OpenCode plugins and skills
RUN mkdir -p ~/.claude/skills ~/.opencode ~/.cache/opencode

# Install pre-commit hooks
RUN if [ -f scripts/security/setup.sh ]; then \
    bash scripts/security/setup.sh || true; \
    fi

# Set up environment
ENV OPENCODE_WORKSPACE=/workspace
ENV NODE_OPTIONS=--max-old-space-size=4096

# Expose OpenCode web port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8080/ || exit 1

# Start OpenCode web server
CMD ["opencode", "web", "--hostname", "0.0.0.0", "--port", "8080"]
