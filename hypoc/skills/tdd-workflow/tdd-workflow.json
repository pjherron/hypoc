{
  "tdd": {
    "enabled": true,
    "approach": "London School",
    "workflow": {
      "steps": [
        "Write failing test",
        "Implement minimum code",
        "Make test pass",
        "Refactor code",
        "Run all tests",
        "Commit when green"
      ]
    },
    "rules": {
      "testFirst": true,
      "mockExternalDependencies": true,
      "isolateTests": true,
      "neverCommitFailingTests": true,
      "alwaysRunTestsAfterChanges": true,
      "refactorWithGreenTests": true
    },
    "testing": {
      "framework": "jest",
      "coverage": {
        "enabled": true,
        "minCoverage": 80
      },
      "watch": true
    },
    "patterns": {
      "testLocation": "tests/",
      "testSuffix": ".spec.ts",
      "mockPrefix": "Mock",
      "fixtureLocation": "tests/fixtures/"
    }
  }
}
