#!/usr/bin/env bash
# Install the hypoc command for this user
# Works on macOS, WSL, and Linux
# Safe to run multiple times; idempotent.

set -euo pipefail

HYPOC_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/hypoc"
HYPOC_LINK="$HOME/.local/bin/hypoc"

# Create ~/.local/bin if needed
mkdir -p "$HOME/.local/bin"

# Symlink hypoc into ~/.local/bin
ln -sf "$HYPOC_BIN" "$HYPOC_LINK"

# Detect shell(s) to update — check in order of preference
# macOS uses .bash_profile for login shells, .bashrc for non-login
# Linux uses .bashrc primarily; zsh uses .zshrc
SHELLS=()
[ -f "$HOME/.bash_profile" ] && SHELLS+=("$HOME/.bash_profile")
[ -f "$HOME/.bashrc" ] && SHELLS+=("$HOME/.bashrc")
[ -f "$HOME/.zshrc" ] && SHELLS+=("$HOME/.zshrc")

if [ ${#SHELLS[@]} -eq 0 ]; then
  # Fallback
  SHELLS=("$HOME/.bash_profile")
fi

# Add ~/.local/bin to PATH in each shell config (if not already there)
for rc in "${SHELLS[@]}"; do
  if ! grep -q 'export PATH.*\.local/bin' "$rc" 2>/dev/null; then
    echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$rc"
    echo "Added ~/.local/bin to PATH in $(basename "$rc")"
  fi
done

echo ""
echo "✓ hypoc installed to $HYPOC_LINK"
echo "✓ Run 'hypoc' from anywhere"
echo ""
echo "To activate in this shell:"
echo "  source $HOME/.zshrc   # zsh"
echo "  source $HOME/.bashrc  # bash"
