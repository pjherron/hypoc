# Hypoc-Face Core - Environment Configuration Template
# Copy to .env and fill in your values

# ============================================================================
# CRITICAL: NO FREE MODELS ALLOWED
# ============================================================================
# All AI model access requires paid enterprise API keys.
# Never use free tiers, anonymous access, or unauthenticated requests.
# ============================================================================

# Database
DATABASE_URL=postgresql://hypoc-face:CHANGE_ME@postgres:5432/hypoc-face

# Redis
REDIS_URL=redis://redis:6379/0

# Authentication
AUTH_PROVIDER=none  # Options: none, cognito_mock, cognito
COGNITO_USER_POOL_ID=
COGNITO_REGION=us-east-1
JWT_SECRET=CHANGE_THIS_TO_LONG_RANDOM_STRING_IN_PRODUCTION

# Application
ENVIRONMENT=development  # development, staging, production
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ============================================================================
# AI Model Providers (ALL REQUIRE PAID ENTERPRISE ACCESS)
# ============================================================================

# AWS Bedrock (GovCloud) - PRIORITY #1
AWS_BEDROCK_REGION=  # e.g. us-gov-west-1 (GovCloud) or us-east-1 (commercial)
AWS_BEDROCK_ACCESS_KEY_ID=  # REQUIRED - Paid enterprise account
AWS_BEDROCK_SECRET_ACCESS_KEY=  # REQUIRED - Never commit this
AWS_BEDROCK_ENABLED=false  # Set to true when keys configured

# Azure OpenAI (Government Cloud) - PRIORITY #2
AZURE_OPENAI_ENDPOINT=  # e.g., https://YOUR-RESOURCE.openai.azure.us/
AZURE_OPENAI_API_KEY=  # REQUIRED - Paid enterprise key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=  # Your deployment name
AZURE_OPENAI_ENABLED=false  # Set to true when configured

# Anthropic Claude (Commercial) - Paid API only
ANTHROPIC_API_KEY=  # REQUIRED - Paid account only (sk-ant-...)
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_ENABLED=false

# OpenAI (Commercial) - Paid API only
OPENAI_API_KEY=  # REQUIRED - Paid account only (sk-...)
OPENAI_ORG_ID=  # Optional organization ID
OPENAI_ENABLED=false

# Ollama (Local/Air-gapped) - Enterprise deployment only
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=false  # Only for enterprise air-gapped scenarios

# ============================================================================
# Cost & Quota Controls
# ============================================================================
ENABLE_COST_TRACKING=true
DEFAULT_MONTHLY_QUOTA_USD=500.00
COST_ALERT_THRESHOLD_PERCENT=80
HARD_QUOTA_ENFORCEMENT=true  # Block requests when quota exceeded

# ============================================================================
# Security
# ============================================================================
ENABLE_AUDIT_LOGGING=true
ENCRYPT_SECRETS_AT_REST=true
REQUIRE_MFA_FOR_ADMIN=false  # Set true in production

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_RAG=false  # Enable when hypoc-face-rag service is deployed
ENABLE_MODEL_ROUTING=false  # Enable when hypoc-face-router is deployed
ENABLE_WORKSPACE_ISOLATION=false  # Enable when hypoc-face-workspace is deployed
